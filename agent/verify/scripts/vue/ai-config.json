{
  "__comment": "Vue 前端验证配置。项目差异优先改本文件，不要直接写死到脚本中。",
  "frontendDir": "double-prevention-vue",
  "__comment_devCommand": "启动开发服务的命令，执行目录为 frontendDir。脚本会从输出中动态解析真实访问地址。",
  "devCommand": "pnpm serve",
  "__comment_baseUrl": "兜底访问地址。正常情况下优先使用 start-dev.js 动态发现并写入 runtimeBaseUrlPath 的地址。",
  "baseUrl": "http://localhost:5173",
  "runtimeBaseUrlPath": "agent/verify/.runtime/vue-base-url.txt",
  "devLogPath": "agent/verify/.runtime/vue-dev-server.log",
  "startupWaitMs": 10000,
  "__comment_outputs": "authStatePath 保存 Playwright 登录态，screenshotDir 保存页面巡检截图，这些目录默认不提交。",
  "authStatePath": "agent/verify/.auth/vue-user.json",
  "screenshotDir": "agent/verify/screenshots/vue",
  "__comment_routerConfigFiles": "用于生成 page-map.json 的 Vue Router 配置文件，可配置多个，路径相对 frontendDir。",
  "routerConfigFiles": [
    "src/router/config.ts"
  ],
  "__comment_checks": "静态检查默认执行；构建检查默认不执行，可通过 buildRequired 或 ai-check.js --build 强制执行。",
  "checks": {
    "lintRequired": false,
    "typecheckRequired": true,
    "typecheckOnlyFailOnSpecifiedFiles": true,
    "buildRequired": false,
    "lintScripts": [
      "lint",
      "lint:check",
      "eslint"
    ],
    "typecheckScripts": [
      "type-check",
      "typecheck",
      "type:check",
      "vue-tsc"
    ],
    "buildScripts": [
      "build",
      "build:prod",
      "build:production"
    ]
  },
  "__comment_auth": "默认 storage 认证：向 localStorage/sessionStorage/cookie 注入 token。必须替换 REPLACE_WITH_TOKEN。",
  "auth": {
    "mode": "storage",
    "storage": {
      "localStorage": [
        {
          "name": "token",
          "value": "REPLACE_WITH_TOKEN"
        }
      ],
      "sessionStorage": [],
      "cookies": []
    },
    "form": {
      "url": "/login",
      "username": "admin",
      "password": "123456",
      "usernameSelector": "#username",
      "passwordSelector": "#password",
      "submitSelector": "button[type=submit]",
      "successUrlContains": "/dashboard"
    }
  },
  "__comment_pageCheck": "页面自动化默认不执行；设置 required=true 或运行 ai-check.js --page 时才启动服务、认证并访问页面。",
  "pageCheck": {
    "required": false,
    "waitUntil": "domcontentloaded",
    "timeoutMs": 15000,
    "readySelector": "",
    "whiteScreenMinTextLength": 10,
    "loginPathIncludes": "/login"
  }
}
